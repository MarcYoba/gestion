{% extends 'base.html.twig' %}

{% block title %}Ticket de Versement{% endblock %}

{% block body %}
<div class="container mt-4" style="max-width: 400px;">
    <div class="card shadow-sm">
        <div class="card-body p-4">
            
            <div class="text-center mb-4">
                <h4 class="fw-bold mb-1">REÇU DE VERSEMENT</h4>
                <p class="text-muted small">N° #{{ versement.id }}</p>
                <hr class="border-2 opacity-75">
            </div>

            <div class="mb-3">
                <div class="d-flex justify-content-between">
                    <span class="text-secondary">Client :</span>
                    <span class="fw-bold">{{ versement.client.nom }}</span>
                </div>
                <div class="d-flex justify-content-between mt-2">
                    <span class="text-secondary">Date paiement :</span>
                    <span>{{ versement.createdAt | date("d/m/Y") }}</span>
                </div>
            </div>

            <div class="bg-light p-2 rounded mb-3">
                {% if versement.om %}
                <div class="d-flex justify-content-between small">
                    <span>Orange/Momo :</span>
                    <span class="fw-bold text-primary">{{ versement.om }}</span>
                </div>
                {% endif %}
                
                {% if versement.banque %}
                <div class="d-flex justify-content-between small mt-1">
                    <span>Banque :</span>
                    <span class="fw-bold">{{ versement.banque }}</span>
                </div>
                {% endif %}
            </div>

            {% if versement.description %}
            <div class="mb-3 border-bottom pb-2">
                <small class="text-muted d-block">Note :</small>
                <p class="fst-italic small mb-0">{{ versement.description }}</p>
            </div>
            {% endif %}

            <div class="text-center mt-4">
                <span class="h6 text-uppercase fw-light">Total Adjugé</span>
                <h2 class="fw-bolder text-success">
                    {{ versement.montant | number_format(0, ',', ' ') }} <small class="h6">FCFA</small>
                </h2>
            </div>

            <div class="text-center mt-4 pt-3 border-top">
                <p class="small text-muted mb-0">Merci de votre confiance !</p>
                <p class="small text-muted" style="font-size: 0.75rem;">
                    Généré le {{ "now"|date("d/m/Y H:i") }}
                </p>
            </div>

        </div>
    </div>
    
    <div class="text-center mt-3 d-print-none">
        
            Entreprise : <strong>{{ agence.nom }}</strong><br>
            Adresse : <strong>{{ agence.adress }}</strong><br>
            Téléphone : <strong>{{ agence.telephone }}</strong><br>
        
    </div>
</div>
{% endblock %}