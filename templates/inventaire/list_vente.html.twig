{% extends 'base.html.twig' %}

{% block title %}StockA{% endblock %}

{% block body %}

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">

    <title>Recapitulatif</title>

</head>

<body id="page-top">
    <div id="wrapper">
        {% include "navbar.html.twig" %}
        <div id="content-wrapper" class="d-flex flex-column">
            <div id="content">
                {% include "topbar.html.twig" %}
                <div class="container-fluid">
                    <h1 class="h3 mb-2 text-gray-800">Liste produit vendu</h1>
                    <p class="mb-4">
                    
                    <div class="card shadow mb-4">
                        <div class="card-header py-3">
                            <div class="row">
                                <div class="col-sm-6 mb-3 mb-sm-0">
                                    <h6 class="m-0 font-weight-bold text-primary">RECAPITULATIF GENERALE</h6>
                                </div>
                                <div class="col-sm-2 mb-3 mb-sm-0">
                                    {% for tempagence in app.user.tempAgences %}
                                        <a href="{{ path('app_home_dashboardA', {'id': tempagence.agence.id}) }}" class="btn btn-primary btn-user btn-block">
                                            <i class="fas fa-home"></i>
                                            home
                                        </a>  
                                    {% endfor %}
                                </div>
                                <div class="col-sm-2">
                                    <a href="{{ path('achat_list')}}" class="btn btn-warning"> 
                                        <i class="fa fa-list"></i>
                                        list
                                    </a>
                                </div> 
                            </div>
                            <br>
                            
                            <div class="row">
                                <p class="col-md-2">
                                    <button class='btn btn-info btn-user'>Imprimer</button>
                                    <br>
                                    <label for="annee">Année recherche :</label>
                                    <select class="form-control" id="annee" name="annee" onchange="reload()">
                                        {% for annee in 2024..2043 %}
                                            <option value="{{ annee }}" {{ annee == anneeselect ? 'selected' : '' }}>
                                                {{ annee }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </p>
                            </div>
                            
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0" data-page-length='80' data-order='[[0, "desc"]]'>
                                    <thead>  
                                        <tr>
                                            <th>Produit</th>
                                            <th>Stock Initial</th>
                                            <th>vendu</th>
                                            <th>Reste</th>
                                            <th>Magasin</th>
                                            <th>Operation</th>
                                        </tr>
                                    </thead>
                                    <tfoot>
                                        <tr>
                                            <th>Produit</th>
                                            <th>Stock Initial</th>
                                            <th>vendu</th>
                                            <th>Reste</th>
                                            <th>Magasin</th>
                                            <th>Operation</th>
                                        </tr>
                                    </tfoot>
                                    <tbody id="liste">
                                        {% for histoique in histoiques %}
                                            <tr>
                                                <th>{{ histoique[1] }}</th>
                                                <th>{{ histoique[2] }}</th>
                                                <th>{{ histoique[3] }}</th>
                                                <th>{{ histoique[4] }}</th>
                                                <th>{{ histoique[5] }}</th>
                                                <th>
                                                    <a href='{{ path('app_inventaire_produit', {'id': histoique[0]}) }}' class='btn btn-primary'><i class='fas fa-pencil-alt'></i></a>
                                                </th>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                </div>
                <!-- /.container-fluid -->

            </div>
            <!-- End of Main Content -->

            <!-- Footer -->
            <footer class="sticky-footer bg-white">
                <div class="container my-auto">
                    <div class="copyright text-center my-auto">
                        <span>Production &copy;  {{ "now" | date("Y") }}</span>
                    </div>
                </div>
            </footer>
            <!-- End of Footer -->

        </div>
        <!-- End of Content Wrapper -->

    </div>
    <!-- End of Page Wrapper -->

    <!-- Scroll to Top Button-->
    <a class="scroll-to-top rounded" href="#page-top">
        <i class="fas fa-angle-up"></i>
    </a>

    <!-- Logout Modal-->

    <!-- Bootstrap core JavaScript-->

</body>

</html>
{% endblock %}
