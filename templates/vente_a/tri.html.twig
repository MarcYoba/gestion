{% extends 'base.html.twig' %}

{% block title %}Trie{% endblock %}

{% block body %}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        /* CSS personnalisé pour le PDF */
        body { font-family: Arial, sans-serif; }
        .header { color: #333; }
        table, th, td {
        border: 1px solid black;
        border-collapse: collapse;
        }
        @Page {
                    footer {
                       position: fixed;
                        bottom: 0cm;
                        left: 0cm;
                        right: 0cm;
                        height: 2cm;
                        text-align: center;
                    }
                }
    </style>
</head>
<body>
<table style="width:100%">
    <thead>
        <tr>
            <th colspan="6" align="center"> trie de Vente du : {{ date | date("Y-m-d") }} ou {{ date2 | date("Y-m-d")}}</th>
        </tr>
    </thead>
        <tbody>
        {%  set sommeVente = 0 %}
        {%   set sommeCash = 0 %}
        {%   set sommeOm = 0 %}
        {%   set sommeCredit = 0 %}
        {%   set sommeReduction = 0 %}
        {%   set sommeQuantite = 0 %}
         
            {% for vente in ventes %}
                {% if clients == "ALL" %}
                    <tr>
                        <td colspan="6" align="center"> Formule   Vente N= {{ vente.id}} / Client : {{ vente.client.nom}} /Tel:{{ vente.client.telephone}}/ utilisateur:{{ vente.user.username}}/ heure: {{ vente.heure}}</td>
                    </tr>
                    <tr>
                        <th scope="col">Nom produit</th>
                        <th scope="col">quantite</th>
                        <th scope="col">prix</th>
                        <th scope="col">montant </th>
                        <th scope="col">Type paiement</th>
                        <th scope="col">date vente</th>
                    </tr>
                    {% for facture in vente.factureAs %}

                        <tr>
                            <td> {{ facture.produit.nom}} </td>
                            <td> {{ facture.quantite}} </td>
                            <td> {{ facture.prix}} </td>
                            <td> {{ facture.prix * facture.quantite}} </td>
                            <td> {{ vente.type}} </td>
                            <td> {{ facture.createAt | date("Y-m-d")}} </td>
                        </tr>
                        {%   set sommeQuantite = sommeQuantite + facture.quantite %}
        
                    {% endfor %} 
                    <tr>
                        <td>Total</td>
                        <td>{{ vente.quantite}}</td>
                        {% if vente.prix != 0 %}
                            <td>{{ vente.prix }}</td>
                        {% else %}
                            <td>0</td>
                        {% endif %}
                        <td>{{ vente.prix}} </td>
                        <td>-</td>
                        <td>-</td>
                    </tr>
                    <tr>
                        <td>Reduction</td>
                        <td>-</td>
                        <td>-</td>
                        <td>{{ vente.reduction}} </td>
                        <td>-</td>
                        <td>-</td>
                    </tr>
                    <tr>
                        <td>Net a payer</td>
                        <td>-</td>
                        <td>-</td>
                        <td>{{ vente.prix}} </td>
                        <td>FCFA</td>
                        <td>{{ vente.type}}</td>
                    </tr>
                    {% set sommeVente = sommeVente + vente.prix %}
                    {% set sommeCash = sommeCash + vente.cash %}
                    {% set sommeCredit = sommeCredit + vente.credit %}
                    {% set sommeOm = sommeOm + vente.momo %}
                    {% set sommeReduction = sommeReduction + vente.reduction %}
                {% elseif clients == vente.client.id %}
                    <tr>
                        <td colspan="6" align="center"> Formule   Vente N= {{ vente.id}} / Client : {{ vente.client.nom}} /Tel:{{ vente.client.telephone}}/ utilisateur:{{ vente.user.username}}/ heure: {{ vente.heure}}</td>
                    </tr>
                    <tr>
                        <th scope="col">Nom produit</th>
                        <th scope="col">quantite</th>
                        <th scope="col">prix</th>
                        <th scope="col">montant </th>
                        <th scope="col">Type paiement</th>
                        <th scope="col">date vente</th>
                    </tr>
                    {% for facture in vente.factureAs %}

                        <tr>
                            <td> {{ facture.produit.nom}} </td>
                            <td> {{ facture.quantite}} </td>
                            <td> {{ facture.prix}} </td>
                            <td> {{ facture.prix * facture.quantite}} </td>
                            <td> {{ vente.type}} </td>
                            <td> {{ facture.createAt | date("Y-m-d")}} </td>
                            {%   set sommeQuantite = sommeQuantite + facture.quantite %}
                        </tr>
                    {% endfor %} 
                    <tr>
                        <td>Total</td>
                        <td>{{ vente.quantite}}</td>
                        {% if vente.prix != 0 %}
                            <td>{{ vente.prix }}</td>
                        {% else %}
                            <td>0</td>
                        {% endif %}
                        <td>{{ vente.prix}} </td>
                        <td>-</td>
                        <td>-</td>
                    </tr>
                    <tr>
                        <td>Reduction</td>
                        <td>-</td>
                        <td>-</td>
                        <td>{{ vente.reduction}} </td>
                        <td>-</td>
                        <td>-</td>
                    </tr>
                    <tr>
                        <td>Net a payer</td>
                        <td>-</td>
                        <td>-</td>
                        <td>{{ vente.prix}} </td>
                        <td>FCFA</td>
                        <td>{{ vente.type}}</td>
                    </tr>
                    {% set sommeVente = sommeVente + vente.prix %}
                    {% set sommeCash = sommeCash + vente.cash %}
                    {% set sommeCredit = sommeCredit + vente.credit %}
                    {% set sommeOm = sommeOm + vente.momo %}
                    {% set sommeReduction = sommeReduction + vente.reduction %}  
                {% endif %}
            {% endfor %}
            
        </tbody>
    </table>
    <br><br><br>
    <table style="width:100%">
        <thead>
            <tr>
                <th colspan="3" align="center"> Quantite Pour chaque produit : {{ date | date("Y-m-d") }} ou {{ date2 | date("Y-m-d")}} </th>
            </tr>
            <tr>
                <th colspan="3" align="center"> Recapitulatif Quantite Vendue </th>
            </tr>
            <tr>
                <th scope="col">Mon du produit </th>
                <th scope="col">Quantite</th>
                <th scope="col">Date</th>
            </tr>
        </thead>
            <tbody>
            {% for historiqueA in historiqueAs %}
                <tr>
                    <th scope="col">{{historiqueA[0]}}</th>
                    <th scope="col">{{historiqueA[1]}}</th>
                    <th scope="col">{{ date | date("Y-m-d")}} ou {{ date2 | date("Y-m-d")}}</th>
                </tr>
            {% endfor %}
            </tbody>
        </thead>
    </table>

    <br><br><br>
    <table style="width:100%">
        <thead>
            <tr>
                <th colspan="3" align="center"> Rapport General : {{ date | date("Y-m-d") }} ou {{ date2 | date("Y-m-d") }} </th>
            </tr>
            <tr>
                <th colspan="3" align="center"> Recapitulatif Quantite / Montant </th>
            </tr>
            <tr>
                <th scope="col">Quantite </th>
                <th scope="col">Montant</th>
                <th scope="col">Date</th>
            </tr>
        </thead>
            <tbody>
            
                <tr>
                    <th scope="col">{{sommeQuantite}}</th>
                    <th scope="col">{{sommeVente}}</th>
                    <th scope="col">{{ date | date("Y-m-d")}} ou {{ date2 | date("Y-m-d")}}</th>
                </tr>
            
            </tbody>
        </thead>
    </table>

    </body>
</html>
{% endblock %}