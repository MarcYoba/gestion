{% extends 'base.html.twig' %}
{% block title %}Fournisseur{% endblock %}
{% block body %}
<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">

    <title>Gestion Stock</title>

</head>

<body id="page-top">

    <!-- Page Wrapper -->
    <div id="wrapper">

        <!-- Sidebar -->
        {% include "navbarC.html.twig" %}
        <!-- End of Sidebar -->

        <!-- Content Wrapper -->
        <div id="content-wrapper" class="d-flex flex-column">

            <!-- Main Content -->
            <div id="content">

                <!-- Topbar -->
                {% include "topbar.html.twig" %}
                <!-- End of Topbar -->

                <!-- Begin Page Content -->
                <div class="container-fluid">

                    <!-- Page Heading -->
                    <h1 class="h3 mb-2 text-gray-800">Fournisseur</h1>
                    <p class="mb-4">

                    <!-- DataTales Example -->
                    <div class="card shadow mb-4">
                        <div class="card-header py-3">
                            <div class="form-group row">
                                <div class="col-sm-8 mb-3 mb-sm-0">
                                    <h6 class="m-0 font-weight-bold text-primary">Liste des fournisseurs</h6>
                                </div>
                                <div class="col-sm-2 mb-3 mb-sm-0">
                                    {% if app.user.employer is not null %}
                                        <a href="{{ path('app_home_dashboardA', {'id': app.user.employer.agence.id}) }}" class="btn btn-success">
                                        <i class="fas fa-home"></i>
                                        Home
                                    </a>
                                    {% else %}
                                        {% for tempagence in app.user.tempAgences %}
                                            <a href="{{ path('app_home_dashboardA', {'id': tempagence.agence.id}) }}" class="btn btn-success">
                                                <i class="fas fa-home"></i>
                                                Home
                                            </a>
                                        {% endfor %}
                                    {% endif %}
                                    
                                </div>  
                                <div class="col-sm-2 mb-3 mb-sm-0">
                                    <a href="{{ path('app_fournisseur_a') }}" class="btn btn-success">
                                        <i class="fas fa-plus"></i>Alouter</a>
                                </div>
                            </div>
                            
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0" data-page-length='25' data-order='[[0, "desc"]]'>
                                    <thead>
                                       
                                        <tr>
                                            <th>id</th>
                                            <th>Nom</th>
                                            <th>adresse</th>
                                            <th>telephone</th>
                                            <th>email</th>
                                            <th>Date enregistrement</th>
                                            <th>numero facture</th>
                                            <th>Agence</th>
                                            <th>Date achat</th>
                                            <th>Action</th>
                                            
                                        </tr>
                                    </thead>
                                    <tfoot>
                                        <tr>
                                            <th>id</th>
                                            <th>Nom</th>
                                            <th>adresse</th>
                                            <th>telephone</th>
                                            <th>email</th>
                                            <th>Date enregistrement</th>
                                            <th>numero facture</th>
                                            <th>Agence</th>
                                            <th>Date achat</th>
                                            <th>Action</th>
                                        </tr>
                                    </tfoot>
                                    <tbody>
                                        {% for fournisseur in fournisseurs %}
                                        <tr>
                                            <td>{{ fournisseur.id }}</td>
                                            <td>{{ fournisseur.nom }}</td>
                                            <td>{{ fournisseur.adress }}</td>
                                            <td>{{ fournisseur.telephone }}</td>
                                            <td>{{ fournisseur.email }}</td>
                                            <td>{{ fournisseur.createdAt|date('d-m-Y') }}</td>
                                            <td>{{ fournisseur.numfacture }}</td>
                                            <td>{{ fournisseur.agence.nom }}</td>
                                            <td>{{ fournisseur.dateAchat|date('d-m-Y') }}</td>
                                            <td>
                                                
                                            </td>
                                        </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                </div>
                <!-- /.container-fluid -->

            </div>
            <!-- End of Main Content -->

            <!-- Footer -->
            <footer class="sticky-footer bg-white">
                <div class="container my-auto">
                    <div class="copyright text-center my-auto">
                        <span>Produiction &copy; {{ "now"|date('d-m-Y') }}</span>
                    </div>
                </div>
            </footer>
            <!-- End of Footer -->

        </div>
        <!-- End of Content Wrapper -->

    </div>

    <a class="scroll-to-top rounded" href="#page-top">
        <i class="fas fa-angle-up"></i>
    </a>

    <!-- Page level custom scripts -->
    <script src="js/demo/datatables-demo.js"></script>

</body>

</html>
{% endblock %}