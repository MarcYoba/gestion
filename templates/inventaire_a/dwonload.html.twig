{% extends 'base.html.twig' %}

{% block title %}Inventaire{% endblock %}

{% block body %}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    {# On intègre Bootstrap via CDN pour les classes de base, 
       mais Dompdf préfère le style local pour le rendu précis #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.0/dist/css/bootstrap.min.css">
    
    <style>
        @page {
            margin: 0.5cm; /* Marges minimales pour gagner de la place */
        }
        body {
            font-family: Arial, sans-serif;
            font-size: 7px; /* Indispensable pour 31 colonnes */
        }
        .table-condensed th, .table-condensed td {
            padding: 2px !important; /* Réduction drastique du padding */
            border: 0.1pt solid #000 !important;
            text-align: center;
            vertical-align: middle;
            word-wrap: break-word;
            white-space: nowrap; /* Empêche le texte de passer à la ligne et de casser la hauteur */
        }
        .table {
            width: 100%;
            table-layout: fixed; /* Force le tableau à respecter la largeur A4 */
        }
        .header-vertical {
            /* Optionnel : Incliner les titres si les noms de colonnes sont longs */
            height: 50px;
        }
    </style>
</head>
<body>

    <h2 class="text-center">Balance Détaillée - 31 Colonnes</h2>

    <table class="table table-bordered table-sm table-striped">
        <thead class="thead-dark">
            <tr>
                <th style="width: 3%;">N°</th>
                <th style="width: 7%;">Compte</th>
                {# Boucle pour générer les 29 autres colonnes de test #}
                {% for i in 1..29 %}
                    <th>Col {{ i }}</th>
                {% endfor %}
            </tr>
        </thead>
        <tbody>
            {% for ligne in balance %}
                <tr>
                    <td>{{ loop.index }}</td>
                    <td>{{ ligne.compte }}</td>
                    {% for i in 1..29 %}
                        <td>{{ random(1000, 9999) }}</td>
                    {% endfor %}
                </tr>
            {% endfor %}
        </tbody>
    </table>

</body>
</html>
{% endblock %}